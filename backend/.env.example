POSTGRES_DB="invoicerr"
POSTGRES_USER="invoicerr_user"
POSTGRES_PASSWORD="password"
DATABASE_URL="postgresql://invoicerr_user:password@localhost:5432/invoicerr"

APP_URL="https://invoicerr.chevrier.dev" # Change this to your production URL

# Mail provider selection: "smtp" (default) or "brevo" (Brevo transactional API)
MAIL_PROVIDER="smtp"
MAIL_FROM="me@host.com" # Sender address used by the Brevo provider (falls back to SMTP_FROM / SMTP_USER)

# SMTP Configuration (used when MAIL_PROVIDER=smtp)
SMTP_HOST="smtp-relay.brevo.com" # Change this to your SMTP host
SMTP_USER="XXXXX@smtp-brevo.com" # Change this to your SMTP user
SMTP_FROM="me@host.com" # Change this to your email address (not required if SMTP_USER is the same)
SMTP_PASSWORD="XXXXX" # Change this to your SMTP password
SMTP_PORT=587 # Change this to your SMTP port (default is 587 for TLS)
SMTP_SECURE=false # Set to true if your SMTP server requires a secure connection (default is false)

# Brevo Configuration (used when MAIL_PROVIDER=brevo)
BREVO_API_KEY="" # Required when MAIL_PROVIDER=brevo; uses the Brevo API instead of SMTP

BETTER_AUTH_URL="http://localhost:3000"

# OIDC Configuration (example for Authentik)
OIDC_ISSUER="https://auth.chevrier.dev"

# Endpoints for OIDC
OIDC_AUTHORIZATION_ENDPOINT="https://auth.chevrier.dev/authorize"
OIDC_TOKEN_ENDPOINT="https://auth.chevrier.dev/token"
OIDC_USERINFO_ENDPOINT="https://auth.chevrier.dev/userinfo"
OIDC_TOKEN_REVOKE_ENDPOINT="https://auth.chevrier.dev/revoke"
OIDC_END_SESSION_ENDPOINT="https://auth.chevrier.dev/end_session"
OIDC_JWKS_URI="https://auth.chevrier.dev/.well-known/jwks.json"

# Client ID and Secret for OIDC
OIDC_CLIENT_ID="your-client-id"
OIDC_CLIENT_SECRET="your-client-secret"


